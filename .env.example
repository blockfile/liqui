# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# DRY_RUN=true simulates all on-chain calls (safe, no funds touched).
# Set to false ONLY after the live transaction paths are wired & validated.
DRY_RUN=true

# ── Solana ───────────────────────────────────────────────────────────────────
RPC_URL=

# Signing wallet. base58 secret key OR a JSON byte array.
# In DRY_RUN you can leave this blank — an ephemeral keypair is generated.
WALLET_PRIVATE_KEY=

# The token you created on pump.fun, and its PumpSwap pool.
TOKEN_MINT=
PUMPSWAP_POOL_ID=

# ── Economics ────────────────────────────────────────────────────────────────
SOL_SPLIT_BUY=0.5        # fraction of spendable SOL used to buy (rest pairs as liquidity)
SOL_RESERVE=0.02         # SOL kept back for tx gas every cycle, never spent
LOCK_YEARS=999           # Streamflow unlock horizon (far-future lock, not a burn)

# Threshold trigger: a cycle runs only once the creator vault reaches this much SOL.
# Higher = more efficient (the fixed lock cost is a smaller % of what's deployed).
CLAIM_THRESHOLD_SOL=1
# SOL held back from each claim to pay the Streamflow lock (measured ≈0.1706/lock).
LOCK_COST_SOL=0.18

# Fee distribution: DEV_FEE_PCT of each claim goes to DEV_WALLET (tech dev),
# the remaining 98% feeds the buy/liquidity/lock flow. Set DEV_FEE_PCT=0 to disable.
DEV_FEE_PCT=2
DEV_WALLET=

# ── On-chain execution (live mode only) ──────────────────────────────────────
SLIPPAGE_PCT=2                    # PumpSwap AMM slippage (convention pending live verification)
CURVE_SLIPPAGE_PCT=5              # bonding-curve buy slippage tolerance, percent
PRIORITY_FEE_MICROLAMPORTS=50000  # compute-unit price for landing txs under load
COMPUTE_UNIT_LIMIT=200000         # compute-unit limit per transaction

# DRY_RUN only: set true to simulate a GRADUATED token (exercises the canonical-pool
# path). Default false simulates the pre-bond path (create/feed our own pool).
SIMULATE_GRADUATED=false

# ── Schedule ─────────────────────────────────────────────────────────────────
# Poll interval: how often to CHECK the vault. A cycle fires only when the vault
# has reached CLAIM_THRESHOLD_SOL — not on every tick.
CRON_SCHEDULE=*/10 * * * *   # check every 10 minutes

# ── Storage (MongoDB) ────────────────────────────────────────────────────────
# Local mongod, or a MongoDB Atlas SRV URI (mongodb+srv://user:pass@cluster/...).
MONGODB_URI=
MONGODB_DB=

# ── Frontend / CORS ──────────────────────────────────────────────────────────
# Comma-separated allowlist of browser origins that may call the API.
# Production: https://yourdomain.com,https://www.yourdomain.com
# Use "*" to allow any origin (not recommended). Non-browser calls always pass.
CORS_ORIGINS=
# Symbol shown in the activity feed (Buy $LIQUI).
TOKEN_SYMBOL=

# Secret protecting POST /api/run|pause|resume. Blank = open (dev only).
# In production set a long random string; send it as header x-api-key: <key>.
API_KEY=
